<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#003d3c"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Logo superior -->
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:maxWidth="438dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logodourado" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:scaleType="centerCrop"
            android:src="@drawable/logosemfundo"
            android:adjustViewBounds="true"
            android:contentDescription="Logo Bless Future no topo" />

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cadastro"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#fff"
            android:layout_marginTop="40dp" />

        <!-- Campo Nome -->
        <EditText
            android:id="@+id/editNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome completo"
            android:textColor="#c9972d"
            android:textColorHint="#c9972d"
            android:padding="12dp"
            android:layout_marginTop="30dp" />

        <!-- Campo E-mail -->
        <EditText
            android:id="@+id/editEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="E-mail"
            android:inputType="textEmailAddress"
            android:textColor="#c9972d"
            android:textColorHint="#c9972d"
            android:padding="12dp"
            android:layout_marginTop="20dp" />

        <!-- Campo Senha -->
        <EditText
            android:id="@+id/editSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Senha"
            android:inputType="textPassword"
            android:textColor="#c9972d"
            android:textColorHint="#c9972d"
            android:padding="12dp"
            android:layout_marginTop="20dp" />

        <!-- Campo Confirmar Senha -->
        <EditText
            android:id="@+id/editConfirmarSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirmar senha"
            android:inputType="textPassword"
            android:textColor="#c9972d"
            android:textColorHint="#c9972d"
            android:padding="12dp"
            android:layout_marginTop="20dp" />

        <!-- Botão Cadastrar -->
        <Button
            android:id="@+id/btnCadastrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadastrar"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="@color/dourado"
            android:layout_marginTop="30dp" />

        <!-- Botão Voltar -->
        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/dourado"
            android:layout_marginTop="20dp"
            android:layout_gravity="center" />

    </LinearLayout>
</ScrollView>
