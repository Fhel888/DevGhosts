<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#003d3c"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:adjustViewBounds="true"
        android:maxWidth="438dp"
        android:scaleType="fitCenter"
        android:src="@drawable/logodourado" />
    <!-- Título -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:scaleType="centerCrop"
        android:src="@drawable/logosemfundo"
        android:adjustViewBounds="true"
        android:contentDescription="Logo Bless Future no topo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bem-vindo ao\nBless Future"
        android:textSize="28sp"
        android:textColor="#c9972d"
        android:textAlignment="center"
        android:textStyle="bold"
        android:layout_marginTop="80dp" />

    <!-- Subtítulo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escolha como deseja navegar"
        android:textSize="18sp"
        android:textColor="#c9972d"
        android:textAlignment="center"
        android:layout_marginTop="20dp" />

    <!-- Palavra destaque -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Processos"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#c9972d"
        android:layout_marginTop="40dp" />

    <!-- Botão Empresa -->
    <Button
        android:id="@+id/btnEmpresa"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="Empresa"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:backgroundTint="@color/dourado"
        android:layout_marginTop="30dp" />

    <!-- Botão Cliente -->
    <Button
        android:id="@+id/btnCliente"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="Cliente"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:backgroundTint="@color/dourado"
        android:layout_marginTop="16dp" />

</LinearLayout>